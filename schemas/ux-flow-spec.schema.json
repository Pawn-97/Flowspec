{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowspec.local/schemas/ux-flow-spec.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "flow",
    "review_profiles",
    "flow_ui_grammar",
    "path_scope",
    "prototype_surface",
    "artifact_contract",
    "acceptance_contract",
    "screens"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "project": { "type": "object", "required": ["id"], "additionalProperties": true },
    "flow": { "type": "object", "required": ["id", "name", "goal"], "additionalProperties": true },
    "review_profiles": { "type": "object", "required": ["primary", "secondary", "excluded"], "additionalProperties": true },
    "flow_ui_grammar": { "type": "object", "required": ["layout_patterns", "component_families"], "additionalProperties": true },
    "path_scope": { "$ref": "#/$defs/pathScope" },
    "prototype_surface": { "$ref": "#/$defs/prototypeSurface" },
    "artifact_contract": { "$ref": "#/$defs/artifactContract" },
    "acceptance_contract": { "$ref": "#/$defs/acceptanceContract" },
    "source_context": { "type": "object", "additionalProperties": true },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "path_role",
          "layout_pattern_id",
          "source_trace",
          "page_purpose",
          "components",
          "interactions",
          "states",
          "validations",
          "prototype_instruction"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string" },
          "path_role": {
            "type": "string",
            "enum": ["happy_path_step", "guardrail_state", "requested_expansion", "out_of_scope_reference"]
          },
          "layout_pattern_id": { "type": "string" },
          "source_trace": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceTrace" } },
          "user_intent": { "type": "string" },
          "page_purpose": { "type": "string" },
          "content_structure": { "type": "object", "additionalProperties": true },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "component_family", "role", "implementation_target"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "component_family": { "type": "string" },
                "role": { "type": "string" },
                "implementation_target": { "$ref": "#/$defs/implementationTarget" },
                "data": { "type": "object", "additionalProperties": true },
                "states": { "type": "array", "items": { "type": "string" } },
                "content": { "type": "object", "additionalProperties": true },
                "source_trace": { "type": "array", "items": { "$ref": "#/$defs/sourceTrace" } }
              },
              "not": { "required": ["shadcn_target"] },
              "additionalProperties": true
            }
          },
          "interactions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "trigger", "result", "destination"],
              "properties": {
                "id": { "type": "string" },
                "trigger": { "type": "string" },
                "condition": { "type": "string" },
                "result": { "type": "string" },
                "destination": { "type": "string" },
                "failure_behavior": { "type": "string" },
                "source_trace": { "type": "array", "items": { "$ref": "#/$defs/sourceTrace" } }
              },
              "additionalProperties": true
            }
          },
          "states": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "message"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "message": { "type": "string" },
                "recovery": { "type": "object", "additionalProperties": true },
                "source_trace": { "type": "array", "items": { "$ref": "#/$defs/sourceTrace" } }
              },
              "additionalProperties": true
            }
          },
          "validations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "prototype_instruction": { "type": "string" },
          "out_of_scope_notes": { "type": "array", "items": { "type": "string" } },
          "needs_confirmation": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "deviation_reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "state_matrix": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "validation_matrix": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "branch_matrix": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "prototype_requirements": { "type": "object", "additionalProperties": true },
    "out_of_scope_items": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
  },
  "additionalProperties": true,
  "$defs": {
    "pathScope": {
      "type": "object",
      "required": ["default_branch_coverage", "included_guardrails", "excluded_paths", "expansion_policy"],
      "properties": {
        "default_branch_coverage": {
          "type": "string",
          "enum": ["happy_path", "happy_path_with_guardrails", "requested_expansion"]
        },
        "included_guardrails": {
          "type": "array",
          "items": { "$ref": "#/$defs/contractItem" }
        },
        "excluded_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/contractItem" }
        },
        "expansion_policy": { "type": "string" }
      },
      "additionalProperties": true
    },
    "prototypeSurface": {
      "type": "object",
      "required": ["skeleton_status"],
      "properties": {
        "skeleton_status": {
          "type": "string",
          "enum": ["none", "draft_pending_user_approval", "approved_default"]
        },
        "skeleton_id": { "type": "string" },
        "implementation_guidance": { "type": "string" }
      },
      "not": {
        "anyOf": [
          { "required": ["ui_library"] },
          { "required": ["target_selection_order"] },
          { "required": ["block_strategy"] }
        ]
      },
      "additionalProperties": true
    },
    "artifactContract": {
      "type": "object",
      "required": ["canonical_source", "handoff_files", "internal_audit_directory"],
      "properties": {
        "canonical_source": { "type": "string" },
        "handoff_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "internal_audit_directory": { "type": "string" }
      },
      "additionalProperties": true
    },
    "acceptanceContract": {
      "type": "object",
      "required": ["implementation_evidence_required", "checks"],
      "properties": {
        "implementation_evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/acceptanceCheckId" },
              {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "$ref": "#/$defs/acceptanceCheckId" },
                  "notes": { "type": "string" }
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "additional_text_checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "acceptanceCheckId": {
      "type": "string",
      "enum": [
        "every_happy_path_step_screen_is_implemented",
        "every_required_component_has_mapping",
        "design_system_choice_is_not_prescribed",
        "implementation_deviations_are_reported",
        "excluded_paths_not_implemented",
        "no_backend_or_api_integration"
      ]
    },
    "implementationTarget": {
      "type": "object",
      "required": ["strategy", "target_role"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["reuse_existing", "compose", "custom"]
        },
        "target_role": { "type": "string" },
        "interaction_shape": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "contractItem": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string" },
            "description": { "type": "string" },
            "source_trace": { "type": "array", "items": { "$ref": "#/$defs/sourceTrace" } }
          },
          "additionalProperties": true
        }
      ]
    },
    "sourceTrace": {
      "type": "object",
      "required": ["source_file", "section", "claim"],
      "properties": {
        "source_file": { "type": "string" },
        "section": { "type": "string" },
        "claim": { "type": "string" },
        "source_type": { "type": "string" },
        "confidence": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
